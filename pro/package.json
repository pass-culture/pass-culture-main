{
  "name": "@pass-culture/pass-culture-pro",
  "version": "531.0.0",
  "private": true,
  "homepage": "/",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:development": "vite build --mode development",
    "build:testing": "vite build --mode testing",
    "build:staging": "vite build --mode staging",
    "build:production": "vite build --mode production",
    "build:integration": "vite build --mode integration",
    "typecheck": "tsgo -b",
    "generate:api:client:local": "./scripts/generate_api_client_local_next.sh",
    "generate:api:client:local:no:docker": "PCAPI_HOST=localhost:5001 ./scripts/generate_api_client_local_next.sh",
    "lint:js": "biome check --diagnostic-level=warn --error-on-warnings --no-errors-on-unmatched",
    "lint:js:fix": "pnpm lint:js --write",
    "lint:scss": "stylelint '**/*.scss'",
    "lint:scss:fix": "pnpm lint:scss --fix",
    "lint:scss:hook": "stylelint",
    "lint:scss:hook:fix": "pnpm lint:scss:hook --fix",
    "lint:scss:checkunused": "check-unused-css --exclude \"src/apiClient/**\"",
    "lint:dead-code": "knip",
    "lint:dead-code:production": "knip --config knip.production.json --production --files",
    "lint:dead-code:fix": "knip --fix --allow-remove-files",
    "serve": "vite preview",
    "start": "vite",
    "test:e2e": "playwright test -c ./config/playwright.config.ts --headed --project=chromium",
    "test:e2e:ci": "playwright test -c ./config/playwright.config.ts --project=chromium",
    "test:e2e:debug": "playwright test -c ./config/playwright.config.ts --debug --project=chromium",
    "test:e2e:mobile": "playwright test -c ./config/playwright.config.ts --headed --project=mobile-chrome",
    "test:e2e:mobile:ci": "playwright test -c ./config/playwright.config.ts --project=mobile-chrome",
    "test:e2e:mobile:debug": "playwright test -c ./config/playwright.config.ts --debug --project=mobile-chrome",
    "test:unit": "vitest",
    "test:unit:hook": "vitest related --run",
    "test:unit:hookcoverage": "vitest related --run --coverage.enabled=true --coverage.100=true",
    "test:unit:ci": "vitest run --coverage",
    "storybook": "NODE_PATH=src storybook dev -p 6006",
    "build-storybook": "NODE_PATH=src storybook build -o docs-build && node scripts/fixStorybookBuild.js",
    "knip": "knip"
  },
  "dependencies": {
    "@algolia/autocomplete-core": "1.19.9",
    "@algolia/autocomplete-plugin-query-suggestions": "1.19.9",
    "@algolia/autocomplete-plugin-recent-searches": "1.19.9",
    "@algolia/autocomplete-preset-algolia": "1.19.9",
    "@firebase/analytics": "0.10.22",
    "@firebase/app": "0.15.1",
    "@firebase/remote-config": "0.9.0",
    "@hookform/resolvers": "5.4.0",
    "@pass-culture/design-system": "0.11.0",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@reduxjs/toolkit": "2.12.0",
    "@sentry/browser": "10.64.0",
    "@sentry/react": "10.64.0",
    "@zootools/email-spell-checker": "1.12.0",
    "algoliasearch": "5.56.0",
    "chart.js": "4.5.1",
    "chartjs-adapter-date-fns": "3.0.0",
    "classnames": "2.5.1",
    "date-fns": "4.4.0",
    "date-fns-tz": "3.2.0",
    "dompurify": "3.4.12",
    "downshift": "9.4.0",
    "libphonenumber-js": "1.13.8",
    "lodash.invert": "4.3.0",
    "qrcode.react": "4.2.0",
    "react": "19.2.7",
    "react-avatar-editor": "15.1.0",
    "react-chartjs-2": "5.3.1",
    "react-dom": "19.2.7",
    "react-dropzone": "15.0.0",
    "react-hook-form": "7.81.0",
    "react-instantsearch": "7.39.0",
    "react-redux": "9.3.0",
    "react-router": "7.18.1",
    "swr": "2.4.2",
    "use-debounce": "10.1.1",
    "uuid": "14.0.1",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@biomejs/biome": "2.5.3",
    "@hey-api/openapi-ts": "0.99.0",
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jsdom": "28.0.3",
    "@types/lodash.invert": "4.3.9",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-istanbul": "4.1.7",
    "axe-core": "4.12.1",
    "check-unused-css": "0.5.5",
    "dotenv": "17.4.2",
    "jsdom": "29.1.1",
    "knip": "6.27.0",
    "node-fetch": "3.3.2",
    "openapi-typescript-codegen": "0.29.0",
    "playwright-core": "1.61.1",
    "prettier": "3.9.5",
    "regenerator-runtime": "0.14.1",
    "rollup-plugin-visualizer": "7.0.1",
    "sass": "1.101.0",
    "storybook": "10.5.0",
    "storybook-addon-remix-react-router": "6.1.0",
    "stylelint": "16.26.1",
    "stylelint-config-standard-scss": "16.0.0",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vite-plugin-html": "3.2.2",
    "vitest": "4.1.7",
    "vitest-axe": "0.1.0",
    "vitest-canvas-mock": "1.1.4",
    "vitest-fail-on-console": "0.10.1",
    "vitest-fetch-mock": "0.4.5"
  },
  "engines": {
    "node": "24.8"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "babel": {
    "presets": [
      "react-app"
    ]
  }
}
